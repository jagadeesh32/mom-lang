// answer.mom — input for the stage-1 mom-in-mom compiler.
//
// After bootstrap: `compiler/bootstrap.sh compiler/examples/answer.mom`
// compiles this to C, links against runtime.c, and runs.
// Expected stdout: 42

fn main() {
    let a = 6
    let b = 7
    let answer = a * b
    print(answer)
}
