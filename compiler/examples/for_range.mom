// for_range.mom — stage-1.2 demo: for-in-range loop, str() conversion.
// Expected output:
//   0
//   1
//   2
//   3
//   sum 0..10 = 45

fn main() {
    for i in 0..4 {
        println(str(i))
    }
    let mut total = 0
    for j in 0..10 {
        total = total + j
    }
    println("sum 0..10 = " + str(total))
}
