// sum.mom — stage-1.2 demo: accumulator loop, function call, str() + println.
// Expected output: 5050

fn sum_to(n: Int) -> Int {
    let mut total = 0
    let mut i = 1
    while i <= n {
        total = total + i
        i = i + 1
    }
    return total
}

fn main() {
    println(str(sum_to(100)))
}
